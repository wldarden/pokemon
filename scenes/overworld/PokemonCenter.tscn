; Invisible collision tilemap — Player._is_blocked reads this exact node
; name via `parent.get_node("Objects")`. Paint any tile whose `solid` custom
; data is true (e.g. the BUSH tiles from frlg_outdoor) to block the player
; on that cell. Modulate alpha 0 keeps it invisible over the background.
[node name="Objects" type="TileMapLayer" parent="."]
modulate = Color(1, 1, 1, 0)
tile_set = ExtResource("7_tileset")

